---
import type { ExerciceEntry } from '../lib/data';
import { localePath, useT, type Lang } from '../i18n/ui';
import { withBase } from '../lib/site';
import Stars from './Stars.astro';

interface Props {
  exo: ExerciceEntry;
  lang: Lang;
}

const { exo, lang } = Astro.props;
const t = useT(lang);
const titre = lang === 'fr' ? exo.titre_fr : exo.titre_en;
---

<a
  class="card exo-card"
  href={withBase(localePath(lang, 'resources', `${exo.id}/`))}
  data-theme-list={exo.theme.join(',')}
  data-niveau={exo.niveau}
  data-difficulte={exo.difficulte}
  data-search={`${titre} ${exo.tags.join(' ')} ${exo.sourceLabel}`.toLowerCase()}
>
  <div class="badges">
    {exo.theme.map((th) => <span class="badge badge-theme">{th}</span>)}
    <span class="badge">{exo.niveau}</span>
  </div>
  <h3>{titre}</h3>
  <p class="muted small">{exo.sourceLabel}</p>
  <div>
    <Stars n={exo.difficulte} lang={lang} />
    {
      exo.a_solution ? (
        <span class="badge" style="margin-left: 0.5rem;">
          ✓ {t('resources.solution')}
        </span>
      ) : null
    }
  </div>
</a>
