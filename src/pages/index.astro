---
// Redirection de la racine vers la langue par défaut (FR).
import { withBase } from '../lib/site';
const target = withBase('fr/');
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title>COMIMa</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={new URL(target, Astro.site)} />
    <script is:inline define:vars={{ target }}>
      // Redirection selon la langue du navigateur (fallback : meta refresh → fr).
      const pref = (navigator.language || 'fr').toLowerCase().startsWith('en') ? 'en' : 'fr';
      location.replace(target.replace(/fr\/$/, pref + '/'));
    </script>
  </head>
  <body>
    <p><a href={target}>COMIMa — version française</a></p>
  </body>
</html>
