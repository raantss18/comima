---
import Base from '../layouts/Base.astro';
import { useT } from '../i18n/ui';
import { withBase } from '../lib/site';

const t = useT('fr');
---

<Base lang="fr" title={t('notfound.title')} currentPath="404" noindex>
  <div class="container" style="text-align: center; padding-block: 4rem;">
    <h1>404</h1>
    <p class="muted">{t('notfound.text')} / {useT('en')('notfound.text')}</p>
    <div class="btn-row" style="justify-content: center;">
      <a class="btn btn-primary" href={withBase('fr/')}>{t('notfound.home')}</a>
      <a class="btn btn-outline" href={withBase('en/')}>Back to home</a>
    </div>
  </div>
</Base>
