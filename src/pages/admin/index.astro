---
import Base from '../../layouts/Base.astro';

// Panneau d'administration sans backend : commits via l'API GitHub (Octokit)
// avec un Personal Access Token collé par l'utilisateur (stocké en localStorage).
---

<Base lang="fr" title="Administration" currentPath="admin/" noindex>
  <div class="container">
    <div class="page-head">
      <h1>Administration</h1>
      <p>
        Publiez articles, événements, exercices et médias directement dans le dépôt GitHub.
        Chaque enregistrement crée un commit sur <code>main</code>, ce qui déclenche
        automatiquement la compilation LaTeX et le redéploiement du site (2 à 5 minutes).
      </p>
    </div>

    <div class="alert alert-warn">
      <strong>⚠️ Sécurité du jeton.</strong> Ce panneau fonctionne sans serveur : votre
      <em>Personal Access Token</em> GitHub est stocké <strong>uniquement dans le
      localStorage de ce navigateur</strong> et n'est transmis qu'à <code>api.github.com</code>.
      Un jeton avec accès en écriture au dépôt permet d'en modifier tout le contenu :
      utilisez un <a href="https://github.com/settings/personal-access-tokens/new" rel="noopener">
      jeton « fine-grained »</a> limité à ce seul dépôt (permission <em>Contents : Read and
      write</em>), avec une date d'expiration courte, et uniquement sur un appareil de
      confiance. Cliquez sur « Oublier le jeton » après usage sur un poste partagé.
    </div>

    <section class="card" style="margin-bottom: 1.5rem;">
      <h2 style="margin-top: 0;">📊 Statistiques du public</h2>
      <p class="muted small" id="stats-status">Chargement…</p>
      <div id="stats-body" hidden>
        <p style="font-size: 1.6rem; font-weight: 700; margin: 0.2rem 0;">
          <span id="stats-total">–</span>
          <span class="muted small" style="font-weight: 400;">visites cumulées</span>
        </p>
        <div class="gen-layout" style="margin-top: 1rem;">
          <div>
            <h3 style="margin: 0 0 0.4rem;">Pages les plus vues</h3>
            <ol class="muted small" id="stats-pages" style="margin: 0; padding-left: 1.2rem;"></ol>
          </div>
          <div>
            <h3 style="margin: 0 0 0.4rem;">Exercices les plus « utiles » 👍</h3>
            <ol class="muted small" id="stats-votes" style="margin: 0; padding-left: 1.2rem;"></ol>
          </div>
        </div>
      </div>
    </section>

    <section class="card" style="margin-bottom: 1.5rem;">
      <h2 style="margin-top: 0;">1 · Connexion</h2>
      <div class="filters" style="border: none; padding: 0; margin: 0;">
        <div class="field" style="margin: 0;">
          <label for="adm-owner">Propriétaire (owner)</label>
          <input type="text" id="adm-owner" value="raantss18" autocomplete="off" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="adm-repo">Dépôt</label>
          <input type="text" id="adm-repo" value="comima" autocomplete="off" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="adm-branch">Branche</label>
          <input type="text" id="adm-branch" value="main" autocomplete="off" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="adm-token">Personal Access Token</label>
          <input type="password" id="adm-token" autocomplete="off" placeholder="github_pat_…" />
        </div>
      </div>
      <div class="btn-row">
        <button class="btn btn-primary" id="adm-connect" type="button">Vérifier & mémoriser</button>
        <button class="btn btn-outline" id="adm-forget" type="button">Oublier le jeton</button>
        <span id="adm-status" class="muted small" role="status"></span>
      </div>
    </section>

    <section class="card" style="margin-bottom: 1.5rem;">
      <h2 style="margin-top: 0;">2 · Article ou événement</h2>
      <div class="filters" style="border: none; padding: 0; margin: 0 0 0.8rem;">
        <div class="field" style="margin: 0;">
          <label for="art-type">Type</label>
          <select id="art-type">
            <option value="article">Article</option>
            <option value="evenement">Événement</option>
          </select>
        </div>
        <div class="field" style="margin: 0;">
          <label for="art-lang">Langue</label>
          <select id="art-lang">
            <option value="fr">Français</option>
            <option value="en">English</option>
          </select>
        </div>
        <div class="field" style="margin: 0;">
          <label for="art-date">Date</label>
          <input type="date" id="art-date" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="art-datefin">Date de fin (événement, optionnel)</label>
          <input type="date" id="art-datefin" />
        </div>
      </div>
      <div class="field">
        <label for="art-titre">Titre</label>
        <input type="text" id="art-titre" />
      </div>
      <div class="field">
        <label for="art-slug">Slug (nom de fichier, auto)</label>
        <input type="text" id="art-slug" placeholder="mon-article" />
      </div>
      <div class="field">
        <label for="art-resume">Résumé (1-2 phrases)</label>
        <textarea id="art-resume" style="min-height: 4rem;"></textarea>
      </div>
      <div class="filters" style="border: none; padding: 0; margin: 0 0 0.8rem;">
        <div class="field" style="margin: 0;">
          <label for="art-lieu">Lieu (événement)</label>
          <input type="text" id="art-lieu" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="art-delegation">Délégation (événement)</label>
          <input type="text" id="art-delegation" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="art-tags">Tags (séparés par des virgules)</label>
          <input type="text" id="art-tags" placeholder="stage, imo" />
        </div>
      </div>
      <div class="field">
        <label for="art-corps">Corps (Markdown)</label>
        <textarea id="art-corps" style="min-height: 12rem;" placeholder="## Titre de section&#10;&#10;Texte…"></textarea>
      </div>
      <div class="btn-row">
        <button class="btn btn-primary" id="art-publish" type="button">Publier (commit)</button>
        <span id="art-status" class="muted small" role="status"></span>
      </div>
    </section>

    <section class="card" style="margin-bottom: 1.5rem;">
      <h2 style="margin-top: 0;">3 · Nouvel exercice</h2>
      <p class="muted small">
        Le commit déclenche la compilation LaTeX en CI : le PDF apparaît sur le site après le
        déploiement.
      </p>
      <div class="filters" style="border: none; padding: 0; margin: 0 0 0.8rem;">
        <div class="field" style="margin: 0;">
          <label for="exo-id">Identifiant (dossier)</label>
          <input type="text" id="exo-id" placeholder="geo-triangle-2026" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="exo-titre-fr">Titre (FR)</label>
          <input type="text" id="exo-titre-fr" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="exo-titre-en">Titre (EN)</label>
          <input type="text" id="exo-titre-en" />
        </div>
      </div>
      <div class="filters" style="border: none; padding: 0; margin: 0 0 0.8rem;">
        <div class="field" style="margin: 0;">
          <label for="exo-themes">Thèmes (virgules)</label>
          <input type="text" id="exo-themes" placeholder="algèbre, géométrie" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="exo-niveau">Niveau</label>
          <select id="exo-niveau">
            <option value="collège">collège</option>
            <option value="lycée" selected>lycée</option>
            <option value="prépa">prépa</option>
          </select>
        </div>
        <div class="field" style="margin: 0;">
          <label for="exo-difficulte">Difficulté (1-5)</label>
          <select id="exo-difficulte">
            <option>1</option><option>2</option><option selected>3</option><option>4</option><option>5</option>
          </select>
        </div>
        <div class="field" style="margin: 0;">
          <label for="exo-tags">Tags (virgules)</label>
          <input type="text" id="exo-tags" />
        </div>
      </div>
      <div class="filters" style="border: none; padding: 0; margin: 0 0 0.8rem;">
        <div class="field" style="margin: 0;">
          <label for="exo-concours">Source : concours</label>
          <input type="text" id="exo-concours" placeholder="Sélection COMIMa" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="exo-annee">Source : année</label>
          <input type="number" id="exo-annee" placeholder="2026" />
        </div>
        <div class="field" style="margin: 0;">
          <label for="exo-pays">Source : pays</label>
          <input type="text" id="exo-pays" placeholder="Madagascar" />
        </div>
      </div>
      <div class="field">
        <label for="exo-enonce">Énoncé (LaTeX, corps seul — sans préambule)</label>
        <textarea id="exo-enonce" style="min-height: 10rem;" placeholder={'Soit $n$ un entier…'}></textarea>
      </div>
      <div class="field">
        <label for="exo-solution">Solution (LaTeX, optionnel)</label>
        <textarea id="exo-solution" style="min-height: 8rem;"></textarea>
      </div>
      <div class="btn-row">
        <button class="btn btn-primary" id="exo-publish" type="button">Publier l'exercice</button>
        <span id="exo-status" class="muted small" role="status"></span>
      </div>
    </section>

    <section class="card">
      <h2 style="margin-top: 0;">4 · Téléverser un média</h2>
      <p class="muted small">
        Le fichier est ajouté dans <code>public/uploads/</code> ; il sera servi à
        l'adresse <code>…/uploads/&lt;nom&gt;</code> après redéploiement (utilisable dans
        les articles avec <code>![alt](/comima/uploads/&lt;nom&gt;)</code>).
      </p>
      <div class="field">
        <label for="up-file">Fichier (image, vidéo courte, PDF…)</label>
        <input type="file" id="up-file" />
      </div>
      <div class="btn-row">
        <button class="btn btn-primary" id="up-publish" type="button">Téléverser</button>
        <span id="up-status" class="muted small" role="status"></span>
      </div>
    </section>
  </div>

  <script>
    import { initAdmin } from '../../scripts/admin';
    initAdmin();
  </script>

  <script>
    import { fetchStats, dataEnabled } from '../../scripts/telemetry';

    const status = document.getElementById('stats-status')!;
    const body = document.getElementById('stats-body')!;

    function list(el: HTMLElement, rows: [string, number][]) {
      el.innerHTML = '';
      rows
        .sort((a, b) => b[1] - a[1])
        .slice(0, 8)
        .forEach(([label, n]) => {
          const li = document.createElement('li');
          li.textContent = `${label.replace(/^page:/, '')} — ${n}`;
          el.append(li);
        });
    }

    (async () => {
      if (!dataEnabled()) {
        status.textContent =
          'Statistiques non configurées. Déployez le Google Apps Script (voir docs/google-apps-script.md) puis collez son URL dans src/lib/config.ts.';
        return;
      }
      const s = await fetchStats();
      if (!s) {
        status.textContent = 'Impossible de récupérer les statistiques (service injoignable).';
        return;
      }
      (document.getElementById('stats-total') as HTMLElement).textContent = String(s.total ?? 0);
      list(document.getElementById('stats-pages') as HTMLElement, s.pages ?? []);
      list(document.getElementById('stats-votes') as HTMLElement, s.votes ?? []);
      status.hidden = true;
      body.hidden = false;
    })();
  </script>
</Base>
