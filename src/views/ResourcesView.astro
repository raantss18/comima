---
import Base from '../layouts/Base.astro';
import ExoCard from '../components/ExoCard.astro';
import { useT, localePath, type Lang } from '../i18n/ui';
import { exercices, themes, niveaux } from '../lib/data';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useT(lang);

const currentPath = localePath(lang, 'resources');
const altPath = localePath(lang === 'fr' ? 'en' : 'fr', 'resources');
---

<Base
  lang={lang}
  title={t('resources.title')}
  description={t('resources.intro')}
  currentPath={currentPath}
  altPath={altPath}
>
  <div class="container">
    <div class="page-head">
      <h1>{t('resources.title')}</h1>
      <p>{t('resources.intro')}</p>
    </div>

    <form class="filters" id="exo-filters" aria-label={t('gen.filters')}>
      <div class="field" style="margin: 0;">
        <label for="f-search">{t('resources.search')}</label>
        <input type="search" id="f-search" name="search" autocomplete="off" />
      </div>
      <div class="field" style="margin: 0;">
        <label for="f-theme">{t('resources.theme')}</label>
        <select id="f-theme" name="theme">
          <option value="">{t('resources.all')}</option>
          {themes.map((th) => <option value={th}>{th}</option>)}
        </select>
      </div>
      <div class="field" style="margin: 0;">
        <label for="f-niveau">{t('resources.level')}</label>
        <select id="f-niveau" name="niveau">
          <option value="">{t('resources.all')}</option>
          {niveaux.map((n) => <option value={n}>{n}</option>)}
        </select>
      </div>
      <div class="field" style="margin: 0;">
        <label for="f-diff">{t('resources.difficulty')}</label>
        <select id="f-diff" name="difficulte">
          <option value="">{t('resources.all')}</option>
          {[1, 2, 3, 4, 5].map((d) => (
            <option value={String(d)}>{'★'.repeat(d)} — {t(`difficulty.${d}` as 'difficulty.1')}</option>
          ))}
        </select>
      </div>
    </form>

    <div class="list-toolbar">
      <p class="muted small" style="margin: 0;">
        <span id="exo-count">{exercices.length}</span> {t('resources.count')}
        <span id="exo-hint" class="muted"></span>
      </p>
      <div class="btn-row" style="margin: 0;">
        <button type="button" class="btn btn-outline btn-sm" id="exo-shuffle">
          {lang === 'fr' ? '↻ Autre sélection' : '↻ Reshuffle'}
        </button>
        <button type="button" class="btn btn-outline btn-sm" id="exo-toggle">
          {lang === 'fr' ? 'Tout afficher' : 'Show all'}
        </button>
      </div>
    </div>

    <div class="cards" id="exo-grid">
      {exercices.map((exo) => <ExoCard exo={exo} lang={lang} />)}
    </div>
    <p class="muted" id="exo-empty" hidden>{t('resources.empty')}</p>
  </div>

  <script>
    const DEFAULT_N = 12;
    const form = document.getElementById('exo-filters') as HTMLFormElement;
    const cards = [...document.querySelectorAll<HTMLElement>('#exo-grid .exo-card')];
    const count = document.getElementById('exo-count')!;
    const empty = document.getElementById('exo-empty')!;
    const hint = document.getElementById('exo-hint')!;
    const toggle = document.getElementById('exo-toggle') as HTMLButtonElement;
    const shuffle = document.getElementById('exo-shuffle') as HTMLButtonElement;
    const lang = (document.documentElement.lang === 'en' ? 'en' : 'fr') as 'fr' | 'en';
    const T = (fr: string, en: string) => (lang === 'fr' ? fr : en);

    let showAll = false;
    let pick: number[] = [];

    function reshuffle() {
      pick = [...cards.keys()].sort(() => Math.random() - 0.5).slice(0, DEFAULT_N);
    }
    reshuffle();

    function criteria() {
      const data = new FormData(form);
      return {
        search: String(data.get('search') ?? '').toLowerCase().trim(),
        theme: String(data.get('theme') ?? ''),
        niveau: String(data.get('niveau') ?? ''),
        diff: String(data.get('difficulte') ?? ''),
      };
    }
    function matches(card: HTMLElement, c: ReturnType<typeof criteria>) {
      return (
        (!c.search || (card.dataset.search ?? '').includes(c.search)) &&
        (!c.theme || (card.dataset.themeList ?? '').split(',').includes(c.theme)) &&
        (!c.niveau || card.dataset.niveau === c.niveau) &&
        (!c.diff || card.dataset.difficulte === c.diff)
      );
    }

    function apply() {
      const c = criteria();
      const filtering = !!(c.search || c.theme || c.niveau || c.diff);
      // Mode « sélection aléatoire courte » tant qu'aucun filtre ni « tout afficher ».
      const randomMode = !filtering && !showAll;
      let visible = 0;
      if (randomMode) {
        const set = new Set(pick);
        cards.forEach((card, i) => (card.hidden = !set.has(i)));
        visible = Math.min(pick.length, cards.length);
      } else {
        for (const card of cards) {
          const ok = matches(card, c);
          card.hidden = !ok;
          if (ok) visible++;
        }
      }
      count.textContent = String(visible);
      empty.hidden = visible > 0;
      hint.textContent = randomMode
        ? T(` — sélection aléatoire sur ${cards.length}, cherchez pour tout explorer`,
            ` — random pick from ${cards.length}, search to explore all`)
        : '';
      shuffle.hidden = !randomMode;
      toggle.hidden = filtering;
      toggle.textContent = showAll ? T('Voir moins', 'Show less') : T('Tout afficher', 'Show all');
    }

    toggle.addEventListener('click', () => {
      showAll = !showAll;
      if (!showAll) reshuffle();
      apply();
    });
    shuffle.addEventListener('click', () => {
      reshuffle();
      apply();
    });
    form.addEventListener('input', apply);
    form.addEventListener('submit', (e) => e.preventDefault());
    apply();
  </script>
</Base>
