---
import Base from '../layouts/Base.astro';
import { useT, localePath, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useT(lang);
const fr = lang === 'fr';

const currentPath = localePath(lang, 'legal');
const altPath = localePath(lang === 'fr' ? 'en' : 'fr', 'legal');
---

<Base lang={lang} title={t('legal.title')} currentPath={currentPath} altPath={altPath} noindex>
  <div class="container">
    <div class="prose">
      <h1>{t('legal.title')}</h1>

      <h2>{fr ? 'Éditeur' : 'Publisher'}</h2>
      <p>
        {
          fr
            ? 'Ce site est édité par le Club Olympiade Mathématiques et Informatique de Madagascar (COMIMa), association nationale présente à Antananarivo, Antsiranana et Ambositra (Madagascar).'
            : 'This website is published by the Mathematics and Computer Science Olympiad Club of Madagascar (COMIMa), a national association present in Antananarivo, Antsiranana and Ambositra (Madagascar).'
        }
      </p>

      <h2>{fr ? 'Hébergement' : 'Hosting'}</h2>
      <p>
        {
          fr
            ? 'Le site est hébergé par GitHub Pages (GitHub, Inc., 88 Colin P. Kelly Jr. Street, San Francisco, CA 94107, États-Unis).'
            : 'The site is hosted by GitHub Pages (GitHub, Inc., 88 Colin P. Kelly Jr. Street, San Francisco, CA 94107, USA).'
        }
      </p>

      <h2>{fr ? 'Données personnelles' : 'Personal data'}</h2>
      <p>
        {
          fr
            ? 'Ce site ne collecte aucune donnée personnelle, ne dépose aucun cookie de suivi et n’utilise aucun outil d’analyse d’audience. Les préférences (thème, panier du générateur) sont stockées uniquement dans le navigateur (localStorage).'
            : 'This site collects no personal data, sets no tracking cookies and uses no analytics. Preferences (theme, generator basket) are stored only in your browser (localStorage).'
        }
      </p>

      <h2>{fr ? 'Sources & propriété intellectuelle' : 'Sources & intellectual property'}</h2>
      <p>
        {
          fr
            ? 'Chaque exercice et chaque sujet indique sa source sur sa page. Les énoncés issus de compétitions officielles (IMO, PAMO, etc.) sont reproduits à des fins pédagogiques non commerciales, avec attribution ; les droits appartiennent à leurs auteurs et aux organisateurs des concours. Toute demande de retrait peut être adressée au club via sa page Facebook.'
            : 'Every exercise and every paper states its source on its own page. Statements from official competitions (IMO, PAMO, etc.) are reproduced for non-commercial educational purposes, with attribution; the rights belong to their authors and to the competition organisers. Any takedown request may be sent to the club via its Facebook page.'
        }
      </p>

      <h2>{fr ? 'Crédits' : 'Credits'}</h2>
      <ul>
        <li>
          {
            fr
              ? 'Énoncés IMO : © IMO (imo-official.org), reproduits à des fins pédagogiques avec attribution.'
              : 'IMO problems: © IMO (imo-official.org), reproduced for educational purposes with attribution.'
          }
        </li>
        <li>
          {
            fr
              ? 'Énoncés PAMO (Olympiade Panafricaine de Mathématiques) : © African Mathematical Union, reproduits à des fins pédagogiques avec attribution.'
              : 'PAMO problems (Pan-African Mathematical Olympiad): © African Mathematical Union, reproduced for educational purposes with attribution.'
          }
        </li>
        <li>
          {
            fr
              ? 'Site construit avec Astro, KaTeX, pdf-lib, JSZip ; polices Inter et Source Serif (SIL OFL).'
              : 'Site built with Astro, KaTeX, pdf-lib, JSZip; Inter and Source Serif typefaces (SIL OFL).'
          }
        </li>
        <li>
          {
            fr
              ? 'Sauf mention contraire, les exercices originaux du club sont librement réutilisables à des fins pédagogiques non commerciales.'
              : 'Unless stated otherwise, the club’s original exercises may be freely reused for non-commercial educational purposes.'
          }
        </li>
      </ul>
    </div>
  </div>
</Base>
