---
import Base from '../layouts/Base.astro';
import { useT, localePath, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useT(lang);

const currentPath = localePath(lang, 'contact');
const altPath = localePath(lang === 'fr' ? 'en' : 'fr', 'contact');

const fr = lang === 'fr';
const FACEBOOK_URL = 'https://www.facebook.com/share/1UrqDjwXJ8/';
---

<Base lang={lang} title={t('contact.title')} currentPath={currentPath} altPath={altPath}>
  <div class="container">
    <div class="page-head">
      <h1>{t('contact.title')}</h1>
      <p>
        {
          fr
            ? 'Le moyen le plus direct de joindre le club est sa page Facebook : annonces, inscriptions et messages passent par là.'
            : 'The most direct way to reach the club is its Facebook page: announcements, registrations and messages all go through it.'
        }
      </p>
    </div>

    <div class="cards">
      <div class="card">
        <h3>📘 Facebook</h3>
        <p class="muted">
          {
            fr
              ? 'Suivez les actualités du club et écrivez-nous directement sur la page officielle COMIMa.'
              : 'Follow the club news and message us directly on the official COMIMa page.'
          }
        </p>
        <a class="btn btn-primary btn-sm" href={FACEBOOK_URL} rel="noopener">
          {fr ? 'Page Facebook COMIMa →' : 'COMIMa Facebook page →'}
        </a>
      </div>
      <div class="card">
        <h3>📍 {fr ? 'Antennes' : 'Branches'}</h3>
        <p class="muted">
          {
            fr
              ? 'COMIMa est une association nationale, présente à :'
              : 'COMIMa is a national association, present in:'
          }
        </p>
        <ul class="muted" style="margin: 0; padding-left: 1.2rem;">
          <li>Antananarivo</li>
          <li>Antsiranana</li>
          <li>Ambositra</li>
        </ul>
      </div>
      <div class="card">
        <h3>🕑 {fr ? 'Séances' : 'Sessions'}</h3>
        <p class="muted">
          {
            fr
              ? 'Séances régulières dans les antennes du club — les horaires et annonces sont publiés sur la page Facebook et dans les actualités du site.'
              : 'Regular sessions in the club branches — schedules and announcements are published on the Facebook page and in the news section.'
          }
        </p>
      </div>
    </div>
  </div>
</Base>
