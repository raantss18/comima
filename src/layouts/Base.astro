---
import '@fontsource-variable/inter';
import '@fontsource-variable/source-serif-4';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useT, type Lang } from '../i18n/ui';
import { withBase } from '../lib/site';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  /** Chemin (sans base) de la même page dans l'autre langue, pour hreflang + switch. */
  altPath?: string;
  /** Chemin (sans base) de la page courante. */
  currentPath: string;
  noindex?: boolean;
}

const { lang, title, description, altPath, currentPath, noindex = false } = Astro.props;
const t = useT(lang);
const desc = description ?? t('site.description');
const otherLang: Lang = lang === 'fr' ? 'en' : 'fr';
const canonical = new URL(withBase(currentPath), Astro.site);
const altUrl = altPath ? new URL(withBase(altPath), Astro.site) : null;
const ogImage = new URL(withBase('logo.png'), Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · COMIMa</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="canonical" href={canonical} />
    {altUrl && <link rel="alternate" hreflang={otherLang} href={altUrl} />}
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="sitemap" href={withBase('sitemap-index.xml')} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="COMIMa" />
    <meta property="og:title" content={`${title} · COMIMa`} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'fr' ? 'en_US' : 'fr_FR'} />
    <meta name="twitter:card" content="summary" />

    <script is:inline>
      // Thème : appliqué avant le premier rendu pour éviter le flash.
      (() => {
        const stored = localStorage.getItem('comima-theme');
        const preferred =
          stored ?? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = preferred;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'fr' ? 'Aller au contenu' : 'Skip to content'}</a>
    <Header lang={lang} altPath={altPath} currentPath={currentPath} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
